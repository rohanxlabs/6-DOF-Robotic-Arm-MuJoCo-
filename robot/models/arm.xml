<mujoco model="robot_arm">
 <compiler angle="radian"/>

 <option timestep="0.002" gravity="0 0 -9.81"/>

 <asset>
  <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
  <texture name="grid" type="2d" builtin="checker" rgb1="0.1 0.2 0.3" rgb2="0.2 0.3 0.4" width="512" height="512"/>
  <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0.2"/>
 </asset>

  <worldbody>
   <light pos="0 0 2" dir="0 0 -1" diffuse="1 1 1"/>
   <geom name="floor" size="0 0 0.5" type="plane" material="grid" condim="3"/>

   <!-- Base -->    
   <body name="base" pos="0 0 0.1">
    <geom type="cylinder" size="0.05 0.05" rgba="0.3 0.3 0.3 1"/>
    <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14" damping="1"/>

    <!-- Link 1 -->
    <body name="link1" pos="0 0 0.1">
     <geom type="capsule" size="0.03" fromto="0 0 0 0 0 0.2" rgba="0.2 0.6 0.9 1"/>
     <joint name="joint2" type="hinge" axis="0 1 0" range="-1.57 1.57" damping="1"/>

     <!-- Link 2 -->
     <body name="link2" pos="0 0 0.2">
      <geom type="capsule" size="0.02" fromto="0 0 0 0 0 0.15" rgba="0.9 0.5 0.2 1"/>
      <joint name="joint3" type="hinge" axis="0 1 0" range="-1.57 1.57" damping="0.8"/>
    
      <!-- Link 3 -->
      <body name="link3" pos="0 0 0.18">
       <geom type="capsule" size="0.02" fromto="0 0 0 0 0 0.15" rgba="0.2 0.8 0.4 1"/>
       <joint name="joint4" type="hinge" axis="0 0 1" range="-3.14 3.14" damping="0.5"/>

       <!-- Link 4 -->
       <body name="link4" pos="0 0 0.15">
        <geom type="capsule" size="0.018" fromto="0 0 0 0 0 0.12" rgba="0.8 0.2 0.5 1"/>
        <joint name="joint5" type="hinge" axis="0 1 0" range="-1.57 1.57" damping="0.4"/>

        <!-- End Effector -->
        <body name="end_effector" pos="0 0 0.12">
         <geom type="sphere" size="0.02" rgba="1 1 0 1"/>
         <site name="ee_site" pos="0 0 0" size="0.01"/>
        </body>
       </body>
      </body>
     </body>
    </body>
   </body>

   <!-- Target Marker -->
    <body name="target" pos="0.3 0 0.2">
     <geom type="sphere" size="0.02" rgba="1 0 0 1" contype="0" conaffinity="0"/>
     <site name="target_site" pos="0 0 0" size="0.01"/>
    </body>
   </worldbody>

    <actuator>
        <motor name="act1" joint="joint1" ctrlrange="-1 1" gear="100" ctrllimited="true"/>
        <motor name="act2" joint="joint2" ctrlrange="-1 1" gear="100" ctrllimited="true"/>
        <motor name="act3" joint="joint3" ctrlrange="-1 1" gear="100" ctrllimited="true"/>
        <motor name="act4" joint="joint4" ctrlrange="-1 1" gear="100" ctrllimited="true"/>
        <motor name="act5" joint="joint5" ctrlrange="-1 1" gear="100" ctrllimited="true"/>
    </actuator>
</mujoco>